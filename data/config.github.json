{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-v4-flash",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 1,
    "languages": [
      "zh"
    ],
    "analysis_concurrency": 5,
    "enrichment_concurrency": 5
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "comfyanonymous",
        "repo": "ComfyUI",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "langgenius",
        "repo": "dify",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "ollama",
        "repo": "ollama",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 120
    },
    "rss": [
      {
        "name": "GitHub Trending - Daily All",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "GitHub Trending - Daily Python",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/python.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "OpenAI News",
        "url": "https://openai.com/news/rss.xml",
        "enabled": true,
        "category": "ai-lab"
      },
      {
        "name": "Google DeepMind Blog",
        "url": "https://deepmind.google/blog/rss.xml",
        "enabled": true,
        "category": "ai-lab"
      },
      {
        "name": "Import AI (Jack Clark)",
        "url": "https://importai.substack.com/feed",
        "enabled": true,
        "category": "ai-newsletter"
      },
      {
        "name": "SemiAnalysis",
        "url": "https://newsletter.semianalysis.com/feed",
        "enabled": true,
        "category": "ai-infra"
      },
      {
        "name": "机器之心",
        "url": "https://www.jiqizhixin.com/rss",
        "enabled": true,
        "category": "ai-cn"
      },
      {
        "name": "量子位",
        "url": "https://www.qbitai.com/feed",
        "enabled": true,
        "category": "ai-cn"
      },
      {
        "name": "36氪",
        "url": "https://36kr.com/feed",
        "enabled": true,
        "category": "tech-cn"
      },
      {
        "name": "TechCrunch",
        "url": "https://techcrunch.com/feed/",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "The Verge",
        "url": "https://www.theverge.com/rss/index.xml",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "MIT Technology Review",
        "url": "https://www.technologyreview.com/feed/",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "Ars Technica",
        "url": "https://feeds.arstechnica.com/arstechnica/index",
        "enabled": false,
        "category": "tech"
      },
      {
        "name": "少数派",
        "url": "https://sspai.com/feed",
        "enabled": false,
        "category": "tech-cn"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 60
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 60
        },
        {
          "subreddit": "StableDiffusion",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 8,
          "min_score": 100
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "ossinsight": {
      "enabled": false,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript"],
      "keywords": [],
      "min_stars": 50,
      "max_items": 20,
      "category": "github-trending"
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24,
    "category_groups": {
      "github": {
        "name": "GitHub 热门",
        "limit": 10,
        "categories": ["github-trending"]
      },
      "ai": {
        "name": "AI 前沿",
        "limit": 15,
        "categories": ["ai", "ai-lab", "ai-newsletter", "ai-infra", "ai-cn"]
      },
      "tech": {
        "name": "科技互联网",
        "limit": 10,
        "categories": ["tech", "tech-cn"]
      }
    },
    "default_group": "other"
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
